1. Largest Odd Number in String

class Solution:
    def largestOddNumber(self, num: str) -> str:
        maxi = 0
        n = len(num)
        val = 0

        for i in range(0,n):
            number = int(num[i])
            if number % 2 != 0:
                temp = num[:i+1]
                if len(temp) > maxi:
                    val = temp
                    maxi = len(temp)

        if maxi == 0:
            return ""
        return val

2. Longest Common Prefix

class Solution:
    def longestCommonPrefix(self, strs: List[str]) -> str:
        small = ""
        minLen = float('inf')
        ans = ""

        for ele in strs:
            if len(ele) < minLen:
                minLen = len(ele)
                small = ele
        
        for i in range(0,len(small)):
            for j in range(0,len(strs)):
                if small[i]!=strs[j][i]:
                    return ans
                
            ans = ans + small[i]
        return ans
        
3. Isomorphic Strings

class Solution:
    def isIsomorphic(self, s: str, t: str) -> bool:
        map1 = {}
        n = len(s)

        for i in range(0,n):
            if s[i] not in map1:
                if t[i] in map1.values():
                    return False
                else:
                    map1[s[i]] = t[i]
        
            else:
                if map1[s[i]] != t[i]:
                    return False
        
        return True

        
